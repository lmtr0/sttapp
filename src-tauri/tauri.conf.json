{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sttapp",
  "version": "1.0.0-alpha",
  "identifier": "com.taresz.sttapp",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "sttapp",
        "width": 400,
        "height": 120,
        "decorations": false,
        "resizable": false,
        "visible": false,
        "alwaysOnTop": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
