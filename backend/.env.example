# Placeholders only. Never commit real credentials.
STTAPP_ENV=development
PROVIDER_ENV=test
PORT=8000
PUBLIC_BASE_URL=http://127.0.0.1:8000
DATABASE_URL=postgres://sttapp:sttapp@127.0.0.1:5432/sttapp
DATABASE_POOL_SIZE=10
DATABASE_TLS=false
INTERNAL_READINESS_TOKEN=replace-with-at-least-32-random-bytes
CORS_ORIGINS=http://127.0.0.1:3000
# Comma-separated direct proxy IPs allowed to supply X-Forwarded-For. Empty by default.
TRUSTED_PROXY_ADDRESSES=

CLERK_ISSUER=https://your-development-instance.clerk.accounts.dev
CLERK_JWKS_URL=https://your-development-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_SIGN_IN_URL=https://your-development-instance.clerk.accounts.dev/sign-in
CLERK_AUTHORIZED_PARTIES=https://your-development-instance.clerk.accounts.dev
CLERK_SECRET_KEY=replace-with-clerk-development-secret
CLERK_WEBHOOK_SECRET=replace-with-clerk-development-webhook-secret

DODO_API_BASE_URL=https://test.dodopayments.com
DODO_API_KEY=replace-with-dodo-test-key
DODO_WEBHOOK_SECRET=replace-with-dodo-test-webhook-secret
DODO_PRODUCT_ID=replace-with-dodo-test-product-id
DODO_METER_TURBO_ID=replace-with-dodo-test-meter-id
DODO_METER_LARGE_ID=replace-with-dodo-test-meter-id
DODO_PORTAL_HOSTS=test.checkout.dodopayments.com

GROQ_API_KEY=replace-with-capped-development-key
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Generate an Ed25519 signing key offline. Public JWKS may contain current and
# previous public keys during rotation. Private JWK contains only the active key.
ACCESS_TOKEN_PRIVATE_JWK={"kty":"OKP","crv":"Ed25519","kid":"replace-me"}
ACCESS_TOKEN_PUBLIC_JWKS={"keys":[{"kty":"OKP","crv":"Ed25519","kid":"replace-me"}]}
ACCESS_TOKEN_KEY_ID=replace-me
REFRESH_TOKEN_PEPPER=replace-with-at-least-32-random-bytes

ACCESS_TOKEN_SECONDS=600
REFRESH_INACTIVITY_SECONDS=2592000
REFRESH_ABSOLUTE_SECONDS=7776000
MAX_BODY_BYTES=26214400
MAX_AUDIO_SECONDS=7200
MAX_CONCURRENT_PER_ACCOUNT=2
MAX_CYCLE_RETAIL_MICROS=5000000
REQUEST_TIMEOUT_MS=120000
WEBHOOK_TOLERANCE_SECONDS=300
RETENTION_DAYS=90
